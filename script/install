#!/usr/bin/env bash
#
# install — run brew bundle and all topic install.sh scripts.

set -e

cd "$(dirname "$0")"/..

# Install Homebrew if missing
if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

echo "Running brew bundle..."
if ! brew bundle; then
  echo "brew bundle had errors, retrying to install cached packages..."
  brew bundle || echo "brew bundle still has errors (see above), continuing..."
fi

# Run topic installers
find . -name install.sh -not -path './script/*' | while read -r installer; do
  echo "Running ${installer}..."
  sh -c "${installer}"
done

# macOS defaults (only on Mac, only if explicitly requested)
if [ "$(uname -s)" == "Darwin" ] && [ "${1}" == "--defaults" ]; then
  echo "Setting macOS defaults..."
  source macos/defaults.sh
fi

echo ""
echo "All installed!"